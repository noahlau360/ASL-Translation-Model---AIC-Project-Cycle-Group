        "### 4.1. MediaPipe Hand Landmarker Initialization and Helper Functions\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "3f73908c",
        "outputId": "44229cc8-02fe-4455-edce-892c794f8367"
      },
      "source": [
        "import cv2\n",
        "import numpy as np\n",
        "import mediapipe as mp\n",
        "from google.colab import files\n",
        "import os\n",
        "import requests\n",
        "\n",
        "# New imports for MediaPipe Tasks API\n",
        "from mediapipe.tasks import python\n",
        "from mediapipe.tasks.python import vision\n",
        "\n",
        "# Define HandLandmarker and related options\n",
        "BaseOptions = python.BaseOptions\n",
        "HandLandmarker = vision.HandLandmarker\n",
        "HandLandmarkerOptions = vision.HandLandmarkerOptions\n",
        "VisionRunningMode = vision.RunningMode\n",
        "\n",
        "# Define HAND_CONNECTIONS for custom drawing\n",
        "HAND_CONNECTIONS = [\n",
        "    (0, 1), (1, 2), (2, 3), (3, 4),        # Thumb\n",
        "    (0, 5), (5, 6), (6, 7), (7, 8),        # Index finger\n",
        "    (0, 9), (9, 10), (10, 11), (11, 12),  # Middle finger\n",
        "    (0, 13), (13, 14), (14, 15), (15, 16), # Ring finger\n",
        "    (0, 17), (17, 18), (18, 19), (19, 20), # Pinky finger\n",
        "    (5, 9), (9, 13), (13, 17)             # Palm connections\n",
        "]\n",
        "\n",
        "def draw_landmarks_on_image(rgb_image, hand_landmarks_list, hand_connections):\n",
        "    annotated_image = np.copy(rgb_image)\n",
        "\n",
        "    if not hand_landmarks_list:\n",
        "        return annotated_image\n",
        "\n",
        "    for hand_landmarks in hand_landmarks_list:\n",
        "        # Draw connections\n",
        "        for connection in hand_connections:\n",
        "            start_node = hand_landmarks[connection[0]]\n",
        "            end_node = hand_landmarks[connection[1]]\n",
        "            start_point = (int(start_node.x * annotated_image.shape[1]), int(start_node.y * annotated_image.shape[0]))\n",
        "            end_point = (int(end_node.x * annotated_image.shape[1]), int(end_node.y * annotated_image.shape[0]))\n",
        "            cv2.line(annotated_image, start_point, end_point, (250, 44, 250), 2)\n",
        "\n",
        "        # Draw landmarks\n",
        "        for landmark in hand_landmarks:\n",
        "            x = int(landmark.x * annotated_image.shape[1])\n",
        "            y = int(landmark.y * annotated_image.shape[0])\n",
        "            cv2.circle(annotated_image, (x, y), 4, (121, 22, 76), -1) # Filled circle\n",
        "\n",
        "    return annotated_image\n",
        "\n",
        "# --- MediaPipe Hand Landmarker Model Download and Initialization ---\n",
        "_INTERNAL_MODEL_PATH_ = 'hand_landmarker.task'\n",
        "_MODEL_DOWNLOAD_URL_ = 'https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/1/hand_landmarker.task'\n",
        "\n",
        "if not os.path.exists(_INTERNAL_MODEL_PATH_):\n",
        "    print(f\"Downloading {_INTERNAL_MODEL_PATH_}...\")\n",
        "    response = requests.get(_MODEL_DOWNLOAD_URL_)\n",
        "    response.raise_for_status() # Raise an exception for bad status codes\n",
        "    with open(_INTERNAL_MODEL_PATH_, 'wb') as f:\n",
        "        f.write(response.content)\n",
        "    print(\"Download complete.\")\n",
        "else:\n",
        "    print(f\"'{_INTERNAL_MODEL_PATH_}' already exists.\")\n",
        "\n",
        "options = HandLandmarkerOptions(\n",
        "    base_options=BaseOptions(model_asset_path=_INTERNAL_MODEL_PATH_),\n",
        "    running_mode=VisionRunningMode.IMAGE,\n",
        "    num_hands=1)\n",
        "\n",
        "hand_landmarker = HandLandmarker.create_from_options(options)\n",
        "\n",
        "# Define a function to extract landmarks from an image using the new API\n",
        "def extract_landmarks(image_path):\n",
        "    image_np = cv2.imread(image_path)\n",
        "    if image_np is None:\n",
        "        print(f\"Error: Could not read image from {image_path}\")\n",
        "        return None, None # Return None for both flattened and raw landmarks\n",
        "\n",
        "    # Convert the image to RGB as MediaPipe expects RGB input for HandLandmarker.detect\n",
        "    image_rgb = cv2.cvtColor(image_np, cv2.COLOR_BGR2RGB)\n",
        "    mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=image_rgb)\n",
        "\n",
        "    # Detect hand landmarks\n",
        "    detection_result = hand_landmarker.detect(mp_image)\n",
        "\n",
        "    flattened_landmarks = []\n",
        "    if detection_result.hand_landmarks:\n",
        "        # Assuming only one hand is detected for simplicity\n",
        "        # We flatten the x, y, z coordinates of the first detected hand\n",
        "        hand_landmarks_for_model = detection_result.hand_landmarks[0]\n",
        "        for landmark in hand_landmarks_for_model:\n",
        "            flattened_landmarks.extend([landmark.x, landmark.y, landmark.z])\n",
        "        return np.array(flattened_landmarks).astype(np.float64), detection_result.hand_landmarks\n",
        "    else:\n",
        "        return None, None # Return None for both"
      ],
      "execution_count": 2,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "'hand_landmarker.task' already exists.\n"
          ]
        }
      ]
